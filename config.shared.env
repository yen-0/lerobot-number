# Tracked non-secret configuration shared across machines.
# Keep secrets such as HF_TOKEN in the ignored config.env file.

# Cluster module for Apptainer.
APPTAINER_MODULE=apptainer

# Apptainer image that contains the LeRobot runtime.
APPTAINER_IMAGE=/work/gw13/share/handson/images/lerobot-v0.5.1.sif 

# Hugging Face cache locations inside the job environment.
HF_HOME=$HOME/.cache/huggingface
HF_LEROBOT_HOME=$HOME/.cache/lerobot
HF_DATASETS_CACHE=$HOME/.cache/huggingface/datasets

# Training overrides.
DATASET_REPO_ID=k1000dai/so101-write
OUTPUT_DIR=./outputs/smolvla_digits
JOB_NAME=smolvla_digits
DEVICE=cuda
STEPS=30000
BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=2
HEARTBEAT_TIMEOUT=120
DIAGNOSTIC_DUMP_INTERVAL=120
FREEZE_VISION_ENCODER=true
TRAIN_EXPERT_ONLY=true
GRADIENT_CHECKPOINTING=true
NUM_WORKERS=4
export LEROBOT_VIDEO_DECODER_CACHE_SIZE=64
MNIST_EXAMPLES_PER_DIGIT=64
# MNIST_CACHE_DIR=/shared/cache/mnist_reference_bank.pt
USE_MNIST=false
# DIGIT_MAP=/path/to/digit_map.json
POLICY_REPO_ID=yen-0/smolvla-so101-digits-0707
PUSH_TO_HUB=true
SAVE_FREQ=5000

# Pattern extraction settings.
EXTRACT_MODE=process
EXTRACT_CROP="386 60 642 238"
EXTRACT_NEW_REPO_ID="yen-0/so101-write-patterns"

# Resource stress-test settings.
STRESS_OUTPUT_DIR=./outputs/resource_stress
STRESS_DISK_TEST_GB=500
STRESS_DISK_CHUNK_MB=64
STRESS_MIN_FREE_GB=5
STRESS_PROGRESS_EVERY_GB=1
STRESS_READ_PASSES=1
STRESS_SMALL_FILES=5000
STRESS_SMALL_FILE_KB=64
STRESS_MEMORY_TEST_GB=56
STRESS_MEMORY_CHUNK_MB=512
STRESS_MEMORY_HOLD_SECONDS=120
STRESS_GPU_MEMORY_TEST_GB=0
STRESS_GPU_MEMORY_CHUNK_MB=512
STRESS_KEEP_FILE=false
STRESS_FSYNC=true
