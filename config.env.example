# Optional local secrets.
# Copy to config.env. That file is intentionally git-ignored.
#
# Non-secret shared settings live in tracked config.shared.env.

# Hugging Face token if the job needs private Hub access or push permission.
# HF_TOKEN=hf_...

# Local-only values. Tracked config.shared.env is sourced after config.env, so
# normal job settings should be changed there instead of here.
# APPTAINER_IMAGE=/path/to/local/lerobot.sif
# HF_HOME=$HOME/.cache/huggingface
# HF_LEROBOT_HOME=$HOME/.cache/lerobot
# HF_DATASETS_CACHE=$HOME/.cache/huggingface/datasets
